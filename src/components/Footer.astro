---
/**
 * Footer Component
 * Static footer displaying copyright info and credits using theme variables
 */
import packageJson from "../../package.json";

const currentYear = new Date().getFullYear();
const authorName = "Yanis Kouidri";
const footerDesc = `Merci de m'avoir lu jusqu'ici. Site écrit par ${authorName} grâce au Framework Astro.`;

const currentVersion = packageJson.version;
---

<footer class="footer-container">
  <div class="footer-content">
    <p class="copyright">
      &copy; {currentYear} - {authorName}
    </p>
    <p class="credits">
      {footerDesc}
    </p>
    <p class="version-tag">
      Version {currentVersion}
    </p>
  </div>
</footer>

<style>
  .footer-container {
    background-color: var(--color-footer);
    border-top: 1px solid rgba(7, 11, 7, 0.1); 
    padding: 2rem 1.5rem;
  }

  .footer-content {
    margin: 0 auto;
    display: block;
    text-align: center;
  }

  .version-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: monospace;
    /* Using a very light background derived from the font color for contrast */
    background-color: rgba(7, 11, 7, 0.05);
    color: var(--color-primary);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    margin-top: 1rem;
    border: 1px solid rgba(0, 110, 26, 0.15);
    transition: background-color 0.2s ease;
  }

  .version-tag:hover {
    background-color: rgba(0, 110, 26, 0.01);
  }

  .copyright {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-font);
    margin: 0 0 0.5rem 0;
  }

  .credits {
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-font);
    opacity: 0.8; /* Slight fade for secondary text hierarchy */
    margin: 0;
  }

  /* --- Desktop Breakpoint (1024px+) --- */
  @media (min-width: 1024px) {
    .footer-container {
      padding: 3rem 2rem;
    }

    .footer-content {
      /* Table layout fallback or simple block centering could work, 
         using explicit block layout adjustments for clean structured output */
      text-align: center;
    }

    .copyright {
      font-size: 1rem;
    }

    .credits {
      font-size: 0.9rem;
    }

    .version-tag {
      font-size: 0.8rem;
      margin-top: 1.25rem;
    }
  }
</style>