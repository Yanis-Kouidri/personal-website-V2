---
import { getCollection } from "astro:content";

/**
 * Load PhD data from the phd content collection
 * (src/content/phd/phd.md)
 */
const phdEntries = await getCollection("phd");
const phdData = phdEntries[0].data;

const {
	title,
	projectCode,
	subtitle,
	period,
	description,
	collaborationText,
	keywords,
	sidebarDetails,
} = phdData;
---

<section id="phd" class="section phd-section">
  <div class="container">
    <header class="phd-header">
      <span class="badge badge--accent period-badge">{period}</span>
      <h2>{title}</h2>
      <div class="project-summary">
        <h3 class="project-id">{projectCode}</h3>
        <p class="project-subtitle">{subtitle}</p>
      </div>
    </header>

    <div class="content-layout">
      <div class="description-column">
        <h4 class="column-label">Aperçu du projet</h4>
        <p class="description-text">
          {description}
        </p>
        
        <div class="tags-group">
          {keywords.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>

      <aside class="details-column">
        <div class="info-card">
          <p class="collaboration-text" set:html={collaborationText} />
          
          <div class="details-grid">
            {sidebarDetails.map((item) => (
              <div class="detail-entry">
                <span class="detail-label">{item.label}</span>
                <span class="detail-value">{item.value}</span>
              </div>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  /* MOBILE FIRST STYLES
  */
  .phd-section {
    color: var(--color-font);
  }

  .phd-header {
    margin-bottom: 3rem;
  }

  .project-summary {
    padding: 1.5rem;
    background-color: white;
    border-left: 5px solid var(--color-accent);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  .project-id {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .project-subtitle {
    font-size: 1.1rem;
    line-height: 1.4;
    font-weight: 500;
    opacity: 0.9;
  }

  /* Layout */
  .content-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .column-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .description-text {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .tags-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  /* Sidebar Card */
  .info-card {
    background-color: var(--color-font);
    color: white;
    padding: 2rem;
    border-radius: 16px;
  }

  .collaboration-text {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .collaboration-text :global(strong) {
    color: var(--color-accent);
  }

  .details-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .detail-entry {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .detail-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #c7c7c7;
    font-weight: 600;
  }

  .detail-value {
    font-weight: 600;
    font-size: 1rem;
  }

  /* DESKTOP ADJUSTMENTS (From 768px)
  */
  @media (min-width: 768px) {
    .phd-section {
      padding: 8rem 2rem;
    }

    .content-layout {
      display: grid;
      grid-template-columns: 1.7fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .info-card {
      position: sticky;
      top: 2rem;
    }
  }
</style>