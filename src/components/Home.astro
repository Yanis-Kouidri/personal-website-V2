---
/**
 * Home Component
 * Implementation of the hero section for mobile view
 */
import { BookMarked, Github, Linkedin, Mail } from "lucide-astro";

// Social links configuration
const socialLinks = [
	{
		href: "https://yanis-kouidri.github.io/personal-doc/",
		icon: BookMarked,
		label: "Docs",
	},
	{
		href: "https://linkedin.com/in/yanis-kouidri",
		icon: Linkedin,
		label: "LinkedIn",
	},
	{
		href: "mailto:yanis.kouidri@neusta.fr",
		icon: Mail,
		label: "Email",
	},
	{
		href: "https://github.com/Yanis-Kouidri",
		icon: Github,
		label: "GitHub",
	},
];
---

<section id="home" class="hero-container">
  <div class="content-wrapper">
    <div class="text-content">
      <h1 class="name-title">Yanis Kouidri</h1>
      <p class="description">
        Doctorant en première année de thèse CIFRE entre l'IRIT et Neusta
      </p>

      <div class="social-links">
        {socialLinks.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label} class="link-icon">
            <social.icon size={32} strokeWidth={2.5} />
          </a>
        ))}
      </div>

      <a href="#phd" class="btn-cta">
        En savoir plus
      </a>
    </div>

    <div class="profile-image-container">
      <img src="src/assets/Yanis_Kouidri_home.jpg" alt="Yanis Kouidri" class="img-cover" />
    </div>
  </div>
</section>

<style>
  .hero-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    background-color: var(--color-background);
    padding: 2rem 1.5rem;
  }

.content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3rem;
    width: 100%;
    max-width: 1200px; 
  }

  .text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }


  @media (min-width: 1024px) {
    .content-wrapper {
      flex-direction: row;
      justify-content: center; /* Changement : on centre le groupe (texte + image) */
      text-align: left;
      
      /* AJUSTEMENTS POUR RAPPROCHER LE CONTENU */
      gap: 8rem;          /* Espace fixe entre le texte et l'image */
      max-width: 1000px;  /* On réduit la largeur maximale pour resserrer l'ensemble */
      margin: 0 auto;     /* On centre le conteneur dans la page */
      padding: 0 10% 6rem 10%;     /* Ajout de marge interne à gauche et à droite */
    }

    .text-content {
      align-items: flex-start;
      flex: 0 1 auto;     /* Le texte ne prend que la place dont il a besoin */
    }

    .profile-image-container {
      flex-shrink: 0;     /* Empêche l'image de rétrécir */
      width: 380px;
      height: 380px;
    }
  }

  .name-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-font);
  }

  .description {
    font-size: 1.25rem;
    max-width: 500px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .profile-image-container {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

</style>

<script>
  const ctaButton = document.querySelector<HTMLAnchorElement>(".btn-cta");

  ctaButton?.addEventListener("click", (e) => {
    e.preventDefault();
    const target = document.getElementById("phd");
    if (target) {
      target.scrollIntoView({ behavior: "smooth" });
    }
  });
</script>