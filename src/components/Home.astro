---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { BookMarked, Mail } from "@lucide/astro";
import { Github } from "simple-icons-astro";
import LinkedinIcon from "./LinkedinIcon.astro";

import profileImage from "../assets/Yanis_Kouidri_home.jpg";

type LucideIcon = typeof BookMarked;
/**
 * Mapping between icon names (from content frontmatter) and Lucide components
 */
const iconMap: Record<string, LucideIcon> = {
  BookMarked,
  Github,
  Mail,
};

const currentLocale = Astro.currentLocale ?? "fr";
const homeEntries = await getCollection("home", (entry) => {
  return entry.data.locale === currentLocale;
});
const homeData = homeEntries[0].data;

const { title, subtitle, ctaLabel, ctaHref, imageAlt, socialLinks } = homeData;
---

<section id="home" class="hero-container">
  <div class="content-wrapper">
    <div class="text-content">
      <h1 class="name-title">{title}</h1>
      <p class="description">
        {subtitle}
      </p>

      <div class="social-links">
        {
          socialLinks.map((social) => {
            const IconComponent =
              social.icon === "Linkedin" ? LinkedinIcon : iconMap[social.icon];
            return (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="link-icon"
              >
                {IconComponent && (
                  <IconComponent size={32} stroke-width="2.5" />
                )}
              </a>
            );
          })
        }
      </div>

      <a href={ctaHref} class="btn-cta">
        {ctaLabel}
      </a>
    </div>

    <div class="profile-image-container">
      <Image
        src={profileImage}
        alt={imageAlt}
        class="img-cover"
        width={380}
        height={380}
      />
    </div>
  </div>
</section>

<style>
  .hero-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    background-color: var(--color-background);
    padding: 2rem 1.5rem;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3rem;
    width: 100%;
    max-width: 1200px;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .content-wrapper {
      flex-direction: row;
      justify-content: center;
      text-align: left;

      gap: 8rem;
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 10% 6rem 10%;
    }

    .text-content {
      align-items: flex-start;
      flex: 0 1 auto;
    }

    .profile-image-container {
      flex-shrink: 0;
      width: 380px;
      height: 380px;
    }
  }

  .name-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-font);
  }

  .description {
    font-size: 1.25rem;
    max-width: 500px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .profile-image-container {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }
</style>

<script>
  const ctaButton = document.querySelector<HTMLAnchorElement>(".btn-cta");

  ctaButton?.addEventListener("click", (e) => {
    e.preventDefault();
    const target = document.getElementById("phd");
    if (target) {
      target.scrollIntoView({ behavior: "smooth" });
    }
  });
</script>
