---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { BookMarked, Github, Linkedin, Mail } from "lucide-astro";
import profileImage from "../assets/Yanis_Kouidri_home.jpg";

type LucideIcon = typeof BookMarked;
/**
 * Mapping between icon names (from content frontmatter) and Lucide components
 */
const iconMap: Record<string, LucideIcon> = {
  BookMarked,
  Github,
  Linkedin,
  Mail,
};

/**
 * Load hero data from the home content collection
 * (src/content/home/hero.md)
 */
const homeEntries = await getCollection("home");
const homeData = homeEntries[0].data;

const { title, subtitle, ctaLabel, ctaHref, imageAlt, socialLinks } = homeData;
---

<section id="home" class="hero-container">
  <div class="content-wrapper">
    <div class="text-content">
      <h1 class="name-title">{title}</h1>
      <p class="description">
        {subtitle}
      </p>

      <div class="social-links">
        {
          socialLinks.map((social) => {
            const IconComponent = iconMap[social.icon];
            return (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="link-icon"
              >
                {IconComponent && <IconComponent size={32} strokeWidth={2.5} />}
              </a>
            );
          })
        }
      </div>

      <a href={ctaHref} class="btn-cta">
        {ctaLabel}
      </a>
    </div>

    <div class="profile-image-container">
      <Image
        src={profileImage}
        alt={imageAlt}
        class="img-cover"
        width={380}
        height={380}
      />
    </div>
  </div>
</section>

<style>
  .hero-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    background-color: var(--color-background);
    padding: 2rem 1.5rem;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3rem;
    width: 100%;
    max-width: 1200px;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .content-wrapper {
      flex-direction: row;
      justify-content: center; /* Changement : on centre le groupe (texte + image) */
      text-align: left;

      /* AJUSTEMENTS POUR RAPPROCHER LE CONTENU */
      gap: 8rem; /* Espace fixe entre le texte et l'image */
      max-width: 1000px; /* On réduit la largeur maximale pour resserrer l'ensemble */
      margin: 0 auto; /* On centre le conteneur dans la page */
      padding: 0 10% 6rem 10%; /* Ajout de marge interne à gauche et à droite */
    }

    .text-content {
      align-items: flex-start;
      flex: 0 1 auto; /* Le texte ne prend que la place dont il a besoin */
    }

    .profile-image-container {
      flex-shrink: 0; /* Empêche l'image de rétrécir */
      width: 380px;
      height: 380px;
    }
  }

  .name-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-font);
  }

  .description {
    font-size: 1.25rem;
    max-width: 500px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .profile-image-container {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }
</style>

<script>
  const ctaButton = document.querySelector<HTMLAnchorElement>(".btn-cta");

  ctaButton?.addEventListener("click", (e) => {
    e.preventDefault();
    const target = document.getElementById("phd");
    if (target) {
      target.scrollIntoView({ behavior: "smooth" });
    }
  });
</script>
