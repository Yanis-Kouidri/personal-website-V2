---
/**
 * AProject Component
 * Clean version: Date moved to a dedicated meta-row above the title.
 */
import { Github } from "lucide-astro";

interface Props {
	title: string;
	description: string;
	technologies: string[];
	githubUrl: string;
	date: string;
	imagePath: string;
	imageAlt?: string;
}

const {
	title,
	description,
	technologies,
	githubUrl,
	date,
	imagePath,
	imageAlt = title,
} = Astro.props;
---

<article class="project-card">
  <div class="image-container">
    <img src={imagePath} alt={imageAlt} class="project-image" />
  </div>

  <div class="project-content">
    <div class="project-meta">
      <span class="project-date">{date}</span>
      <a 
        href={githubUrl} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="github-link"
        aria-label={`View ${title} source code on GitHub`}
      >
        <Github size={20} />
      </a>
    </div>

    <h3 class="project-title">{title}</h3>

    <p class="project-description">{description}</p>

    <div class="tech-stack">
      {technologies.map((tech) => (
        <span class="tech-tag">{tech}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    background-color: white;
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0px 4px 6px -1px rgb(0 0 0 / 0.1);
    transition: transform 0.3s ease;
    height: 100%;
    border: 0.5px black solid;
  }

  .project-card:hover {
    transform: translateY(-5px);
  }

  .image-container {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    box-shadow: 5px 5px 15px rgba(0, 0, 0, 0.3);

  }

  .project-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  /* Fixed Project Date - No more absolute positioning */
  .project-date {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    background-color: var(--color-secondary); /* Using your chart color */
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .github-link {
    color: var(--color-font);
    opacity: 0.6;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .github-link:hover {
    opacity: 1;
    color: var(--color-primary);
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-font);
    margin: 0 0 0.75rem 0;
  }

  .project-description {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-font);
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .tech-tag {
    background-color: var(--color-background);
    color: var(--color-font);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
</style>