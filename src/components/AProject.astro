---
/**
 * AProject Component
 * Clean version: Date moved to a dedicated meta-row above the title.
 */
import { Github } from "lucide-astro";

interface Props {
	title: string;
	description: string;
	technologies: string[];
	githubUrl: string;
	date: string;
	imagePath: string;
	imageAlt?: string;
}

const {
	title,
	description,
	technologies,
	githubUrl,
	date,
	imagePath,
	imageAlt = title,
} = Astro.props;
---

<article class="project-card card card--hover">
  <div class="image-container">
    <img src={imagePath} alt={imageAlt} class="img-cover project-image" />
  </div>

  <div class="project-content">
    <div class="project-meta">
      <span class="badge badge--date">{date}</span>
      <a 
        href={githubUrl} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="github-link"
        aria-label={`View ${title} source code on GitHub`}
      >
        <Github size={20} />
      </a>
    </div>

    <h3 class="project-title">{title}</h3>

    <p class="project-description">{description}</p>

    <div class="tech-stack">
      {technologies.map((tech) => (
        <span class="tag tag--neutral">{tech}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 0.5px black solid;
  }

  .image-container {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .project-image {
    box-shadow: 5px 5px 15px rgba(0, 0, 0, 0.3);
  }

  .project-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .github-link {
    color: var(--color-font);
    opacity: 0.6;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .github-link:hover {
    opacity: 1;
    color: var(--color-primary);
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-font);
    margin: 0 0 0.75rem 0;
  }

  .project-description {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-font);
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

</style>