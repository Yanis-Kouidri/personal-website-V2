---
import { getEntry } from "astro:content";
import { Briefcase, Globe, GraduationCap } from "lucide-astro";

// Fetch the single experience file from the journey collection
const journeyEntry = await getEntry("journey", "journey");
const journeyData = journeyEntry?.data?.items ?? [];

/**
 * Maps the experience type to its corresponding Lucide icon component
 * @param type - The type of journey item
 */
function getIcon(type: "academic" | "professional" | "international") {
  switch (type) {
    case "professional":
      return Briefcase;
    case "international":
      return Globe;
    default:
      return GraduationCap;
  }
}
---

<section id="journey" class="section journey-section">
  <div class="container">
    <h2>Mon Parcours</h2>

    <div class="timeline">
      {
        journeyData.map((item) => {
          const Icon = getIcon(item.type);
          return (
            <div class="timeline-item">
              <div class="timeline-marker">
                <div class="timeline-icon">
                  <Icon size={18} />
                </div>
                <div class="timeline-line" />
              </div>

              <div class="timeline-content">
                <span class="badge badge--pill period-badge">
                  {item.period}
                </span>
                <h3 class="job-title">{item.title}</h3>
                <p class="org-info">
                  <strong>{item.organization}</strong>{" "}
                  <span class="location">| {item.location}</span>
                </p>

                {item.description && (
                  <p class="description">{item.description}</p>
                )}

                {item.details && (
                  <ul class="details-list">
                    {item.details.map((detail) => (
                      <li>{detail}</li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
  }

  /* --- Marker (Icon + Line) --- */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .timeline-icon {
    width: 36px;
    height: 36px;
    background-color: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    background-color: var(--color-secondary);
    opacity: 0.4;
    margin-top: -2px; /* Smooth connection */
  }

  /* Remove line from the last item */
  .timeline-item:last-child .timeline-line {
    display: none;
  }

  /* --- Content Block --- */
  .timeline-content {
    padding-bottom: 3rem;
    text-align: left !important;
    width: 100%;
  }

  .period-badge {
    margin-bottom: 2.5rem;
    margin-top: 0.4rem;
  }

  .job-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.3rem 0;
    color: var(--color-font);
  }

  .org-info {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .location {
    font-weight: 400;
    color: #666;
  }

  .description {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.8rem;
    color: var(--color-font);
  }

  .details-list {
    margin: 0;
    padding-left: 1.2rem;
    font-size: 0.9rem;
    color: #444;
    list-style-type: disc;
  }

  .details-list li {
    margin-bottom: 0.4rem;
  }
</style>
