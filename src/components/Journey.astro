---
/**
 * Journey Component
 * Vertical timeline with consistent left-aligned content.
 */
import { Briefcase, Globe, GraduationCap } from "lucide-astro";

interface JourneyItem {
	title: string;
	organization: string;
	location: string;
	period: string;
	description?: string;
	details?: string[];
	type: "academic" | "professional" | "international";
}

const journeyData: JourneyItem[] = [
	{
		title: "Doctorat (Thèse CIFRE)",
		organization: "IRIT & Neusta France",
		location: "Toulouse, France",
		period: "2026 - Present",
		description:
			"Sujet : Dorsales de communication éphémères pour la collecte de données dans les réseaux de capteurs sans fil (WSN).",
		type: "academic",
	},
	{
		title: "Chargé de développement logiciel (Rust)",
		organization: "Thales Alenia Space",
		location: "Toulouse, France",
		period: "Mars 2025 - Sept. 2025",
		description:
			"Projet de fin d'étude : Développement d'une bibliothèque Rust pour le démultiplexage de données satellites.",
		details: [
			"Étude des recommandations du CCSDS pour les télécommunications.",
			"Conception logicielle pour le traitement de flux de données complexes.",
		],
		type: "professional",
	},
	{
		title: "Semestre Erasmus",
		organization: "Université de Rome Tor Vergata",
		location: "Italie",
		period: "2024",
		description:
			"Échange international axé sur le secteur spatial et numérique.",
		details: [
			"Internet par satellite & Systèmes de navigation.",
			"Cybersécurité & Cloud Computing.",
		],
		type: "international",
	},
	{
		title: "Diplôme d'Ingénieur (Alternance)",
		organization: "ENSEEIHT",
		location: "Toulouse, France",
		period: "2022 - 2025",
		description:
			"Filière Sciences du Numérique. Alternance chez Thales Alenia Space.",
		details: [
			"Cloud & DevOps : Kubernetes, Argo Workflow, Luigi.",
			"Docs as Code : Antora et Jenkins.",
			"Analyse comparative d'orchestrateurs de données.",
		],
		type: "academic",
	},
	{
		title: "Développeur d'outils d'exploitation de données",
		organization: "Thales Alenia Space",
		location: "Cannes, France",
		period: "Avril 2022 - Sept. 2022",
		description:
			"Stage de fin de DUT : Analyse de données binaires avioniques.",
		details: [
			"Python Data Science : NumPy, Pandas, Matplotlib (Bus CAN).",
			"Réseaux : Conversion de captures PCAP.",
		],
		type: "professional",
	},
	{
		title: "DUT Réseaux & Télécommunications",
		organization: "IUT de Nice",
		location: "Sophia-Antipolis, France",
		period: "2020 - 2022",
		description: "Télécoms, Réseaux et Informatique.",
		type: "academic",
	},
	{
		title: "Baccalauréat Scientifique",
		organization: "Lycée Jules Ferry",
		location: "Cannes, France",
		period: "2020",
		description: "Spécialité Mathématiques | Mention Très Bien.",
		type: "academic",
	},
];

const getIcon = (type: string) => {
	switch (type) {
		case "professional":
			return Briefcase;
		case "international":
			return Globe;
		default:
			return GraduationCap;
	}
};
---

<section id="journey" class="journey-section">
  <div class="container">
    <h2>Mon Parcours</h2>
    
    <div class="timeline">
      {journeyData.map((item) => {
        const Icon = getIcon(item.type);
        return (
          <div class="timeline-item">
            <div class="timeline-marker">
              <div class="timeline-icon">
                <Icon size={18} />
              </div>
              <div class="timeline-line"></div>
            </div>
            
            <div class="timeline-content">
              <span class="period-badge">{item.period}</span>
              <h3 class="job-title">{item.title}</h3>
              <p class="org-info">
                <strong>{item.organization}</strong> <span class="location">| {item.location}</span>
              </p>
              
              {item.description && <p class="description">{item.description}</p>}
              
              {item.details && (
                <ul class="details-list">
                  {item.details.map((detail) => (
                    <li>{detail}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .journey-section {
    padding: 4rem 1.5rem;
    background-color: var(--color-background);
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
  }

  /* --- Marker (Icon + Line) --- */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .timeline-icon {
    width: 36px;
    height: 36px;
    background-color: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    background-color: var(--color-secondary);
    opacity: 0.4;
    margin-top: -2px; /* Smooth connection */
  }

  /* Remove line from the last item */
  .timeline-item:last-child .timeline-line {
    display: none;
  }

  /* --- Content Block --- */
  .timeline-content {
    padding-bottom: 3rem; /* Space between items */
    text-align: left !important;
    width: 100%;
  }

  .period-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    background: var(--color-secondary);
    padding: 0.2rem 0.8rem;
    border-radius: 50px;
    margin-bottom: 0.6rem;
  }

  .job-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.3rem 0;
    color: var(--color-font);
  }

  .org-info {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .location {
    font-weight: 400;
    color: #666;
  }

  .description {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.8rem;
    color: var(--color-font);
  }

  .details-list {
    margin: 0;
    padding-left: 1.2rem;
    font-size: 0.9rem;
    color: #444;
    list-style-type: disc;
  }

  .details-list li {
    margin-bottom: 0.4rem;
  }

  /* Simple responsive adjustments */
  @media (min-width: 1024px) {
    .container {
      padding-left: 2rem;
    }
  }
</style>