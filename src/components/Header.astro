---
import { getCollection } from "astro:content";
import { Menu, X } from "lucide-astro";

const currentLocale = Astro.currentLocale ?? "fr";
const headerEntries = await getCollection("header", (entry) => {
  return entry.data.locale === currentLocale;
});
const headerData = headerEntries[0].data;

const mainLinks = headerData.navLinks;
const contactLink = headerData.contactLink;
const brandName = headerData.brandName;
---

<header>
  <nav class="nav-bar">
    <div class="nav-identity">
      <a id="brand-name" href="/">{brandName}</a>
    </div>

    <ul class="nav-menu-desktop">
      {
        mainLinks.map((link) => (
          <li>
            <a href={link.href} class="nav-item">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="nav-actions">
      <div class="lang-switcher">
        <button
          id="lang-button"
          type="button"
          class="lang-btn"
          aria-label="Switch language"
          aria-expanded="false"
        >
          {
            currentLocale === "fr" ? (
              <svg
                class="flag-icon"
                viewBox="0 0 3 2"
                xmlns="http://www.w3.org/2000/svg"
              >
                <rect width="1" height="2" fill="#002395" />
                <rect x="1" width="1" height="2" fill="#FFF" />
                <rect x="2" width="1" height="2" fill="#ED2939" />
              </svg>
            ) : currentLocale === "en" ? (
              <svg
                class="flag-icon"
                viewBox="0 0 60 30"
                xmlns="http://www.w3.org/2000/svg"
              >
                <clipPath id="uk-clip">
                  <path d="M0 0v30h60V0z" />
                </clipPath>
                <g clip-path="url(#uk-clip)">
                  <path d="M0 0v30h60V0z" fill="#012169" />
                  <path
                    d="M0 0l60 30m0-30L0 30"
                    stroke="#FFF"
                    stroke-width="6"
                  />
                  <path
                    d="M0 0l60 30m0-30L0 30"
                    clip-path="url(#uk-clip)"
                    stroke="#C8102E"
                    stroke-width="4"
                  />
                  <path d="M0 15h60M30 0v30" stroke="#FFF" stroke-width="10" />
                  <path
                    d="M0 15h60M30 0v30"
                    stroke="#C8102E"
                    stroke-width="6"
                  />
                </g>
              </svg>
            ) : (
              <svg
                class="flag-icon"
                viewBox="0 0 9 6"
                xmlns="http://www.w3.org/2000/svg"
              >
                <rect width="9" height="6" fill="#FFF" />
                <rect y="0" width="9" height="2" fill="#0039A6" />
                <rect y="4" width="9" height="2" fill="#D52B1E" />
              </svg>
            )
          }
          <span class="lang-label">
            {
              currentLocale === "fr"
                ? "FR"
                : currentLocale === "en"
                  ? "EN"
                  : "RU"
            }
          </span>
          <svg
            class="lang-chevron"
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <ul id="lang-dropdown" class="lang-dropdown">
          <li>
            <a
              href="/"
              class={`lang-option ${currentLocale === "fr" ? "active" : ""}`}
            >
              <svg
                class="flag-icon"
                viewBox="0 0 3 2"
                xmlns="http://www.w3.org/2000/svg"
              >
                <rect width="1" height="2" fill="#002395"></rect>
                <rect x="1" width="1" height="2" fill="#FFF"></rect>
                <rect x="2" width="1" height="2" fill="#ED2939"></rect>
              </svg>
              Français
            </a>
          </li>
          <li>
            <a
              href="/en/"
              class={`lang-option ${currentLocale === "en" ? "active" : ""}`}
            >
              <svg
                class="flag-icon"
                viewBox="0 0 60 30"
                xmlns="http://www.w3.org/2000/svg"
              >
                <clipPath id="uk-clip-mobile"
                  ><path d="M0 0v30h60V0z"></path></clipPath
                >
                <g clip-path="url(#uk-clip-mobile)">
                  <path d="M0 0v30h60V0z" fill="#012169"></path>
                  <path d="M0 0l60 30m0-30L0 30" stroke="#FFF" stroke-width="6"
                  ></path>
                  <path
                    d="M0 0l60 30m0-30L0 30"
                    clip-path="url(#uk-clip-mobile)"
                    stroke="#C8102E"
                    stroke-width="4"></path>
                  <path d="M0 15h60M30 0v30" stroke="#FFF" stroke-width="10"
                  ></path>
                  <path d="M0 15h60M30 0v30" stroke="#C8102E" stroke-width="6"
                  ></path>
                </g>
              </svg>
              English
            </a>
          </li>
          <li>
            <a
              href="/ru/"
              class={`lang-option ${currentLocale === "ru" ? "active" : ""}`}
            >
              <svg
                class="flag-icon"
                viewBox="0 0 9 6"
                xmlns="http://www.w3.org/2000/svg"
              >
                <rect width="9" height="6" fill="#FFF"></rect>
                <rect y="0" width="9" height="2" fill="#0039A6"></rect>
                <rect y="4" width="9" height="2" fill="#D52B1E"></rect>
              </svg>
              Русский
            </a>
          </li>
        </ul>
      </div>

      <a href={contactLink.href} class="contact-cta-desktop">
        {contactLink.label}
      </a>

      <button
        id="menu-button"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <Menu id="icon-menu" class="nav-icon" />
        <X id="icon-close" class="nav-icon hidden" />
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu-overlay">
    {
      [...mainLinks, contactLink].map((link) => (
        <a href={link.href} class="mobile-nav-link">
          {link.label}
        </a>
      ))
    }
    <div class="mobile-lang-divider"></div>
    <div class="mobile-lang-options">
      <a
        href="/"
        class={`mobile-lang-link ${currentLocale === "fr" ? "active" : ""}`}
      >
        <svg
          class="flag-icon"
          viewBox="0 0 3 2"
          xmlns="http://www.w3.org/2000/svg"
        >
          <rect width="1" height="2" fill="#002395"></rect>
          <rect x="1" width="1" height="2" fill="#FFF"></rect>
          <rect x="2" width="1" height="2" fill="#ED2939"></rect>
        </svg>
        Français
      </a>
      <a
        href="/en/"
        class={`mobile-lang-link ${currentLocale === "en" ? "active" : ""}`}
      >
        <svg
          class="flag-icon"
          viewBox="0 0 60 30"
          xmlns="http://www.w3.org/2000/svg"
        >
          <clipPath id="uk-clip-mob"><path d="M0 0v30h60V0z"></path></clipPath>
          <g clip-path="url(#uk-clip-mob)">
            <path d="M0 0v30h60V0z" fill="#012169"></path>
            <path d="M0 0l60 30m0-30L0 30" stroke="#FFF" stroke-width="6"
            ></path>
            <path
              d="M0 0l60 30m0-30L0 30"
              clip-path="url(#uk-clip-mob)"
              stroke="#C8102E"
              stroke-width="4"></path>
            <path d="M0 15h60M30 0v30" stroke="#FFF" stroke-width="10"></path>
            <path d="M0 15h60M30 0v30" stroke="#C8102E" stroke-width="6"></path>
          </g>
        </svg>
        English
      </a>
      <a
        href="/ru/"
        class={`mobile-lang-link ${currentLocale === "ru" ? "active" : ""}`}
      >
        <svg
          class="flag-icon"
          viewBox="0 0 9 6"
          xmlns="http://www.w3.org/2000/svg"
        >
          <rect width="9" height="6" fill="#FFF"></rect>
          <rect y="0" width="9" height="2" fill="#0039A6"></rect>
          <rect y="4" width="9" height="2" fill="#D52B1E"></rect>
        </svg>
        Русский
      </a>
    </div>
  </div>
</header>

<style>
  /* --- Base Navigation (Mobile First) --- */
  .nav-bar {
    background-color: var(--color-background);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    position: relative;
    z-index: 20;
    border-bottom: 1px rgba(0, 0, 0, 0.12) solid;
  }

  #brand-name {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-font);
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }

  #brand-name:hover {
    color: var(--color-font);
  }

  /* Hide desktop-specific elements by default */
  .nav-menu-desktop,
  .contact-cta-desktop,
  .lang-switcher {
    display: none;
  }

  #menu-button {
    border: 0;
    background: transparent;
    cursor: pointer;
    color: var(--color-font);
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-icon {
    transition:
      transform 0.2s ease-in-out,
      color 0.2s ease-in-out;
  }

  #menu-button:hover .nav-icon {
    color: var(--color-primary);
    transform: scale(1.1);
  }

  /* --- Language Switcher Dropdown (Desktop) --- */
  .lang-switcher {
    position: relative;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-font);
    transition: border-color 0.2s ease;
  }

  .lang-btn:hover {
    border-color: var(--color-primary);
  }

  .flag-icon {
    width: 24px;
    height: 16px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .lang-label {
    font-size: 0.8rem;
  }

  .lang-chevron {
    transition: transform 0.2s ease;
  }

  .lang-btn[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    list-style: none;
    margin: 0;
    padding: 0.4rem;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    min-width: 150px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease,
      transform 0.2s ease;
  }

  .lang-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-font);
    font-size: 0.9rem;
    font-weight: 500;
    transition: background-color 0.15s ease;
  }

  .lang-option:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .lang-option.active {
    background-color: rgba(0, 110, 26, 0.08);
    color: var(--color-primary);
    font-weight: 600;
  }

  /* --- Mobile Overlay Styles --- */
  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--color-background);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    transform: translateY(-100%);
    transition: transform 0.3s ease-in-out;
    z-index: 10;
  }

  .mobile-menu-overlay.is-open {
    transform: translateY(0);
  }

  .mobile-nav-link {
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-font);
    transition:
      color 0.2s ease-in-out,
      transform 0.2s ease-in-out;
  }

  .mobile-nav-link:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  .mobile-lang-divider {
    width: 60px;
    height: 1px;
    background-color: rgba(0, 0, 0, 0.15);
  }

  .mobile-lang-options {
    display: flex;
    gap: 1.5rem;
  }

  .mobile-lang-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: var(--color-font);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    transition: background-color 0.15s ease;
  }

  .mobile-lang-link:hover,
  .mobile-lang-link.active {
    background-color: rgba(0, 110, 26, 0.08);
    color: var(--color-primary);
  }

  /* --- Desktop Breakpoint (1024px+) --- */
  @media (min-width: 1024px) {
    .nav-bar {
      display: grid;
      grid-template-columns: 1fr auto 1fr; /* Centering trick */
      padding: 1rem 2rem;
    }

    /* Show desktop elements */
    .nav-menu-desktop {
      display: flex;
      list-style: none;
      gap: 2rem;
      margin: 0;
      padding: 0;
    }

    .nav-item {
      text-decoration: none;
      color: var(--color-font);
      font-weight: 500;
      position: relative;
      padding: 0.25rem 0;
      transition: color 0.25s ease-in-out;
      border-bottom: 2px solid transparent;
    }

    /* Elegant sliding underline animation for desktop items */
    .nav-item::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background-color: var(--color-primary);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform 0.25s ease-in-out;
    }

    .nav-item:hover {
      color: var(--color-primary);
    }

    .nav-item:hover::after {
      transform: scaleX(1);
      transform-origin: left;
    }

    .contact-cta-desktop {
      display: inline-block;
      text-decoration: none;
      background-color: var(--color-primary);
      color: var(--color-background);
      padding: 0.6rem 1.5rem;
      border-radius: 50px;
      font-weight: 600;
      transition:
        transform 0.2s ease-in-out,
        filter 0.2s ease-in-out,
        box-shadow 0.2s ease-in-out;
    }

    .contact-cta-desktop:hover {
      transform: translateY(-2px);
      filter: brightness(1.1);
      box-shadow: 0 4px 12px rgba(0, 110, 26, 0.2);
      border: 1px solid var(--color-primary);
    }

    .contact-cta-desktop:active {
      transform: translateY(0);
    }

    .nav-actions {
      justify-self: end;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .lang-switcher {
      display: block;
    }

    /* Hide mobile-only elements */
    #menu-button,
    .mobile-menu-overlay {
      display: none;
    }
  }
</style>

<script>
  /**
   * Setup interactive navigation behavior
   */
  const setupNavigation = (): void => {
    const toggleBtn = document.getElementById(
      "menu-button",
    ) as HTMLButtonElement | null;
    const menuOverlay = document.getElementById(
      "mobile-menu",
    ) as HTMLElement | null;
    const openIcon = document.getElementById("icon-menu") as HTMLElement | null;
    const closeIcon = document.getElementById(
      "icon-close",
    ) as HTMLElement | null;

    if (!toggleBtn || !menuOverlay || !openIcon || !closeIcon) return;

    // Toggle menu state
    const toggleMenu = (isOpen: boolean): void => {
      menuOverlay.classList.toggle("is-open", isOpen);
      toggleBtn.setAttribute("aria-expanded", isOpen.toString());

      if (isOpen) {
        openIcon.classList.add("hidden");
        closeIcon.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      } else {
        openIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        document.body.style.overflow = "";
      }
    };

    toggleBtn.addEventListener("click", () => {
      const isExpanded = menuOverlay.classList.contains("is-open");
      toggleMenu(!isExpanded);
    });

    // Close mobile menu gracefully when a link is clicked
    const mobileLinks = menuOverlay.querySelectorAll(".mobile-nav-link");
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        toggleMenu(false);
      });
    });
  };

  /**
   * Setup language switcher dropdown behavior (desktop)
   */
  const setupLangSwitcher = (): void => {
    const langBtn = document.getElementById(
      "lang-button",
    ) as HTMLButtonElement | null;
    const langDropdown = document.getElementById(
      "lang-dropdown",
    ) as HTMLElement | null;

    if (!langBtn || !langDropdown) return;

    // Toggle dropdown on button click
    langBtn.addEventListener("click", (event) => {
      event.stopPropagation();
      const isOpen = langDropdown.classList.toggle("is-open");
      langBtn.setAttribute("aria-expanded", isOpen.toString());
    });

    // Close dropdown on outside click
    document.addEventListener("click", (event) => {
      if (
        !langBtn.contains(event.target as Node) &&
        !langDropdown.contains(event.target as Node)
      ) {
        langDropdown.classList.remove("is-open");
        langBtn.setAttribute("aria-expanded", "false");
      }
    });

    // Close dropdown on Escape
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        langDropdown.classList.remove("is-open");
        langBtn.setAttribute("aria-expanded", "false");
        langBtn.focus();
      }
    });
  };

  // Initialize on DOM load
  setupNavigation();
  setupLangSwitcher();
</script>
