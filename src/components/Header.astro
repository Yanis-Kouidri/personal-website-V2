---
import { getCollection } from "astro:content";
import { Menu, X } from "lucide-astro";

/**
 * Load navigation data from the header content collection
 * (src/content/header/header.md)
 */
const headerEntries = await getCollection("header");
const headerData = headerEntries[0].data;

const mainLinks = headerData.navLinks;
const contactLink = headerData.contactLink;
const brandName = headerData.brandName;
---

<header>
  <nav class="nav-bar">
    <div class="nav-identity">
      <a id="brand-name" href="/">{brandName}</a>
    </div>

    <ul class="nav-menu-desktop">
      {mainLinks.map((link) => (
        <li><a href={link.href} class="nav-item">{link.label}</a></li>
      ))}
    </ul>

    <div class="nav-actions">
      <a href={contactLink.href} class="contact-cta-desktop">
        {contactLink.label}
      </a>
      
      <button id="menu-button" type="button" aria-label="Toggle menu" aria-expanded="false">
        <Menu id="icon-menu" class="nav-icon" />
        <X id="icon-close" class="nav-icon hidden" />
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu-overlay">
    {[...mainLinks, contactLink].map((link) => (
      <a href={link.href} class="mobile-nav-link">{link.label}</a>
    ))}
  </div>
</header>

<style>
  /* --- Base Navigation (Mobile First) --- */
  .nav-bar {
    background-color: var(--color-background);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    position: relative;
    z-index: 20;
    border-bottom: 1px rgba(0, 0, 0, 0.12) solid;
  }

  #brand-name {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-font);
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }

  #brand-name:hover {
    color: var(--color-primary);
  }

  /* Hide desktop-specific elements by default */
  .nav-menu-desktop, 
  .contact-cta-desktop {
    display: none;
  }

  #menu-button {
    border: 0;
    background: transparent;
    cursor: pointer;
    color: var(--color-font);
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-icon {
    transition: transform 0.2s ease-in-out, color 0.2s ease-in-out;
  }

  #menu-button:hover .nav-icon {
    color: var(--color-primary);
    transform: scale(1.1);
  }

  /* --- Mobile Overlay Styles --- */
  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--color-background);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    transform: translateY(-100%);
    transition: transform 0.3s ease-in-out;
    z-index: 10;
  }

  .mobile-menu-overlay.is-open {
    transform: translateY(0);
  }

  .mobile-nav-link {
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-font);
    transition: color 0.2s ease-in-out, transform 0.2s ease-in-out;
  }

  .mobile-nav-link:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  /* --- Desktop Breakpoint (1024px+) --- */
  @media (min-width: 1024px) {
    .nav-bar {
      display: grid;
      grid-template-columns: 1fr auto 1fr; /* Centering trick */
      padding: 1rem 2rem;
    }

    /* Show desktop elements */
    .nav-menu-desktop {
      display: flex;
      list-style: none;
      gap: 2rem;
      margin: 0;
      padding: 0;
    }

    .nav-item {
      text-decoration: none;
      color: var(--color-font);
      font-weight: 500;
      position: relative;
      padding: 0.25rem 0;
      transition: color 0.25s ease-in-out;
      border-bottom: 2px solid transparent; /* To avoid inherit for <a> global style */
    }

    /* Elegant sliding underline animation for desktop items */
    .nav-item::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background-color: var(--color-primary);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform 0.25s ease-in-out;
    }

    .nav-item:hover {
      color: var(--color-primary);
    }

    .nav-item:hover::after {
      transform: scaleX(1);
      transform-origin: left;
    }

    .contact-cta-desktop {
      display: inline-block;
      text-decoration: none;
      background-color: var(--color-primary);
      color: var(--color-background);
      padding: 0.6rem 1.5rem;
      border-radius: 50px;
      font-weight: 600;
      transition: transform 0.2s ease-in-out, filter 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

    .contact-cta-desktop:hover {
      transform: translateY(-2px);
      filter: brightness(1.1);
      box-shadow: 0 4px 12px rgba(0, 110, 26, 0.2); /* Soft shadow using --color-primary */
    }

    .contact-cta-desktop:active {
      transform: translateY(0);
    }

    .nav-actions {
      justify-self: end;
    }

    /* Hide mobile-only elements */
    #menu-button, 
    .mobile-menu-overlay {
      display: none;
    }
  }
</style>

<script>
  /**
   * Setup interactive navigation behavior
   */
  const setupNavigation = (): void => {
    const toggleBtn = document.getElementById("menu-button") as HTMLButtonElement | null;
    const menuOverlay = document.getElementById("mobile-menu") as HTMLElement | null;
    const openIcon = document.getElementById("icon-menu") as HTMLElement | null;
    const closeIcon = document.getElementById("icon-close") as HTMLElement | null;

    if (!toggleBtn || !menuOverlay || !openIcon || !closeIcon) return;

    // Toggle menu state
    const toggleMenu = (isOpen: boolean): void => {
      menuOverlay.classList.toggle("is-open", isOpen);
      toggleBtn.setAttribute("aria-expanded", isOpen.toString());
      
      if (isOpen) {
        openIcon.classList.add("hidden");
        closeIcon.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      } else {
        openIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        document.body.style.overflow = "";
      }
    };

    toggleBtn.addEventListener("click", () => {
      const isExpanded = menuOverlay.classList.contains("is-open");
      toggleMenu(!isExpanded);
    });

    // Close mobile menu gracefully when a link is clicked
    const mobileLinks = menuOverlay.querySelectorAll(".mobile-nav-link");
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        toggleMenu(false);
      });
    });
  };

  // Initialize on DOM load
  setupNavigation();
</script>