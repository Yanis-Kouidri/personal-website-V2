---
import { getCollection } from "astro:content";
import { Bitcoin, FileText, Github, Linkedin, Mail } from "lucide-astro";

/** Display social links and contact points from content collection */

const iconMap: Record<string, typeof Linkedin> = {
  Linkedin,
  Mail,
  FileText,
  Github,
  Bitcoin,
};

const currentLocale = Astro.currentLocale ?? "fr";
const contactEntries = await getCollection("contacts", (entry) => {
  return entry.data.locale === currentLocale;
});
const contactData = contactEntries[0]?.data;

const contactMessage: string = contactData?.message ?? "";
const contactLinks = contactData?.links ?? [];
---

<section id="contact" class="section contact-section">
  <div class="container">
    <h2>Contact</h2>
    <p class="section-subtitle">{contactMessage}</p>

    <div class="contact-grid">
      {
        contactLinks.map((contact) => {
          const Icon = iconMap[contact.icon];
          return (
            <a
              href={contact.href}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-card card card--hover"
              aria-label={contact.label}
            >
              <div class="icon-wrapper">
                {Icon && <Icon size={32} stroke-width="1.5" />}
              </div>
              <span class="contact-label">{contact.label}</span>
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .contact-section {
    display: flex;
    justify-content: center;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    border-radius: 16px;
    text-decoration: none;
    color: var(--color-font);
  }

  .icon-wrapper {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    transition: transform 0.3s ease;
  }

  .contact-label {
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* Hover states */
  .contact-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    border-color: var(--color-secondary);
  }

  .contact-card:hover .icon-wrapper {
    transform: scale(1.1);
    color: var(--color-accent);
  }

  /* Desktop adjustments */
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: repeat(5, 1fr);
    }

    .section-title {
      font-size: 2.5rem;
    }

    .contact-section {
      padding: 10rem 1.5rem 20rem 1.5rem;
    }
  }
</style>
