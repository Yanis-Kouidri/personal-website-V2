{
	"name": "personal-website-v2",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev --open",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "biome format",
		"format:fix": "biome format --write",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"check": "biome check",
		"check:fix": "biome check --write",
		"typecheck": "astro check",
		"typecheck:watch": "astro check --watch",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,astro,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@astrojs/check": "^0.9.6",
		"@tailwindcss/vite": "^4.2.0",
		"astro": "^5.17.1",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.3",
		"@types/bun": "^1.3.9",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7"
	}
}
