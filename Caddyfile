{
    auto_https off
}

:8080 {
    root * /usr/share/caddy
    
    encode gzip zstd
    
    try_files {path} /index.html
    
    file_server
    
    log {
        output stdout
        format json
    }

	header {
        Content-Security-Policy "default-src 'none'; img-src 'self' data:; style-src 'self'; upgrade-insecure-requests;"
        
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}